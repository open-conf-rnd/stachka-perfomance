{
  "name": "stachka-perfomance",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "frontend",
    "api",
    "ws"
  ],
  "scripts": {
    "export:presentation-pdf": "node scripts/export-presentation-pdf.mjs",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:api": "npm run dev --workspace=api",
    "dev:ws": "npm run dev --workspace=ws",
    "build": "npm run build --workspaces --if-present",
    "build:frontend": "npm run build --workspace=frontend",
    "build:api": "npm run build --workspace=api",
    "build:ws": "npm run build --workspace=ws",
    "test:smoke": "npm run test:smoke --workspace=api",
    "test:smoke:watch": "npm run test:smoke:watch --workspace=api"
  },
  "devDependencies": {
    "pdf-lib": "^1.17.1",
    "playwright": "^1.51.0"
  }
}
