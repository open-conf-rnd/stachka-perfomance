# Dev: только frontend — Vite dev server
# Сборка: context = frontend/ (docker build -f frontend/Dockerfile.dev frontend/)
FROM node:22-alpine

WORKDIR /app

COPY package.json ./
RUN npm install

COPY . .

EXPOSE 5173

# node_modules в контейнере — отдельный volume; npm install заполняет его при старте
CMD ["sh", "-c", "npm install && npm run dev"]
