# Dev: только api — tsx watch
# Сборка: context = api/ (docker build -f api/Dockerfile.dev api/)
FROM node:22-alpine

WORKDIR /app

COPY package.json ./
RUN npm install

COPY . .

EXPOSE 3000

# Apply migrations then start dev server (DATABASE_URL from env at runtime)
CMD ["sh", "-c", "npx prisma migrate deploy && npm run dev"]
