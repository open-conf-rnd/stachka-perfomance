    "@prisma/client": "^7.4.2",
    "dotenv": "^16.6.1",
    "fastify": "^5.1.0",
    "pg": "^8.20.0",
    "prisma": "^7.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.18.0",
    "tsx": "^4.19.2",
    "typescript": "~5.6.2",
    "vitest": "^2.1.8"
  }
}
