{
  "name": "api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "test:smoke": "ADMIN_USER_IDS= DATABASE_URL=${DATABASE_URL:-postgresql://stachka:stachka@localhost:5432/stachka} REACTION_COUNTDOWN_SECONDS=0 REACTION_LEADERBOARD_DELAY_SECONDS=0 vitest run test/smoke.test.ts",
    "test:smoke:watch": "DATABASE_URL=${DATABASE_URL:-postgresql://stachka:stachka@localhost:5432/stachka} REACTION_COUNTDOWN_SECONDS=0 REACTION_LEADERBOARD_DELAY_SECONDS=0 vitest test/smoke.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
