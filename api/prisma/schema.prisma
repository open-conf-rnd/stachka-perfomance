generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum IdentityProvider {
  telegram
  vk
}

model User {
  id          String            @id @default(cuid())
  username    String?
  firstName   String
  lastName    String?
  photoUrl    String?
  /// Согласие на обработку ПДн при регистрации (152-ФЗ)
  personalDataConsentAt DateTime?
  tapCount    Int               @default(0)
  completions BingoCompletion[]
  votes       Vote[]
  reactionTaps   ReactionTap[]
  hapticTriggers HapticTrigger[]
  merge2048Stats Merge2048Stats?
  identities  UserIdentity[]
  createdAt   DateTime          @default(now())
}

/// Агрегированная статистика 2048 для лидерборда (попытки и лучшие результаты).
model Merge2048Stats {
  userId      String   @id
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bestMaxTile Int      @default(0)
  bestScore   Int      @default(0)
  gamesPlayed Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@index([bestMaxTile(sort: Desc), bestScore(sort: Desc)])
}

model UserIdentity {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider   IdentityProvider
  externalId String
  createdAt  DateTime         @default(now())

  @@unique([provider, externalId])
  @@index([userId])
}

model HapticTrigger {
  id         String   @id @default(cuid())
  userId     String
  triggerKey String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([userId, triggerKey])
}

model Poll {
  id              String   @id @default(cuid())
  question        String
  correctOptionId String? @unique
  options         Option[] @relation("PollOptions")
  votes           Vote[]
  createdAt       DateTime @default(now())
  correctOption   Option?  @relation("PollCorrectOption", fields: [correctOptionId], references: [id], onDelete: SetNull)
}

model Option {
  id               String @id @default(cuid())
  pollId           String
  poll             Poll   @relation("PollOptions", fields: [pollId], references: [id])
  label            String
  votes            Vote[]
  correctAnswerFor Poll?  @relation("PollCorrectOption")
}

model Vote {
  id       String @id @default(cuid())
  pollId   String
  optionId String
  userId   String
  poll     Poll   @relation(fields: [pollId], references: [id])
  option   Option @relation(fields: [optionId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@unique([pollId, userId])
}

model BingoTask {
  id          String            @id @default(cuid())
  title       String
  description String?
  order       Int               @default(0)
  completions BingoCompletion[]
  qrCodes     QrCode[]
  createdAt   DateTime          @default(now())
}

model BingoCompletion {
  id        String    @id @default(cuid())
  taskId    String
  userId    String
  task      BingoTask @relation(fields: [taskId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())

  @@unique([taskId, userId])
}

model QrCode {
  id        String    @id @default(cuid())
  code      String    @unique
  taskId    String
  task      BingoTask @relation(fields: [taskId], references: [id])
  createdAt DateTime  @default(now())
}

model ReactionRound {
  id        String         @id @default(cuid())
  status    ReactionStatus @default(PENDING)
  taps      ReactionTap[]
  createdAt DateTime       @default(now())
}

enum ReactionStatus {
  PENDING
  ACTIVE
  FINISHED
}

model ReactionTap {
  id      String        @id @default(cuid())
  roundId String
  userId  String
  round   ReactionRound @relation(fields: [roundId], references: [id])
  user    User          @relation(fields: [userId], references: [id])
  tapTime DateTime      @default(now())

  @@unique([roundId, userId])
}

/// Одна строка с id = 1: открыто ли «окно» тапов (ведущий управляет через админку).
model TapSessionState {
  id      Int     @id
  tapOpen Boolean @default(true)
}

model FeatureGate {
  key       String   @id
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Одноразовый токен для привязки Telegram ↔ VK без двух заголовков в одном запросе
model AccountLinkToken {
  id        String    @id @default(cuid())
  token     String    @unique
  vkUserId  String?
  tgExtId   String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([expiresAt])
}
