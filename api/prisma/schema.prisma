generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum IdentityProvider {
  telegram
  vk
}

model User {
  id          String            @id @default(cuid())
  username    String?
  firstName   String
  lastName    String?
  photoUrl    String?
  tapCount    Int               @default(0)
  completions BingoCompletion[]
  votes       Vote[]
  reactionTaps   ReactionTap[]
  hapticTriggers HapticTrigger[]
  identities  UserIdentity[]
  createdAt   DateTime          @default(now())
}

model UserIdentity {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider   IdentityProvider
  externalId String
  createdAt  DateTime         @default(now())

  @@unique([provider, externalId])
  @@index([userId])
}

model HapticTrigger {
  id         String   @id @default(cuid())
  userId     String
  triggerKey String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([userId, triggerKey])
}

model Poll {
  id        String   @id @default(cuid())
  question  String
  options   Option[]
  votes     Vote[]
  createdAt DateTime @default(now())
}

model Option {
  id     String @id @default(cuid())
  pollId String
  poll   Poll   @relation(fields: [pollId], references: [id])
  label  String
  votes  Vote[]
}

model Vote {
  id       String @id @default(cuid())
  pollId   String
  optionId String
  userId   String
  poll     Poll   @relation(fields: [pollId], references: [id])
  option   Option @relation(fields: [optionId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@unique([pollId, userId])
}

model BingoTask {
  id          String            @id @default(cuid())
  title       String
  description String?
  order       Int               @default(0)
  completions BingoCompletion[]
  qrCodes     QrCode[]
  createdAt   DateTime          @default(now())
}

model BingoCompletion {
  id        String    @id @default(cuid())
  taskId    String
  userId    String
  task      BingoTask @relation(fields: [taskId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())

  @@unique([taskId, userId])
}

model QrCode {
  id        String    @id @default(cuid())
  code      String    @unique
  taskId    String
  task      BingoTask @relation(fields: [taskId], references: [id])
  createdAt DateTime  @default(now())
}

model ReactionRound {
  id        String         @id @default(cuid())
  status    ReactionStatus @default(PENDING)
  taps      ReactionTap[]
  createdAt DateTime       @default(now())
}

enum ReactionStatus {
  PENDING
  ACTIVE
  FINISHED
}

model ReactionTap {
  id      String        @id @default(cuid())
  roundId String
  userId  String
  round   ReactionRound @relation(fields: [roundId], references: [id])
  user    User          @relation(fields: [userId], references: [id])
  tapTime DateTime      @default(now())

  @@unique([roundId, userId])
}

model FeatureGate {
  key       String   @id
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
