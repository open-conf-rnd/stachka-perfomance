# Admin: comma-separated Telegram user IDs. Empty = allow all (dev).
# ADMIN_USER_IDS=7409015534

# Telegram Bot API (для бота Mini App)
TG_BOT_API=your_bot_token
# Домен бота (без @)
TG_DOMAIN=your_bot_username

# Домен для HTTPS при разработке (обязателен для теста в клиенте Telegram).
# BotFather принимает только валидный HTTPS-URL; localhost не подходит.
# Укажите домен туннеля (ngrok, cloudflared и т.п.) или свой домен.
# После смены домена заново выполните: ./scripts/gen-ssl.sh
DOMAIN=localhost

# API (REST) — порт сервиса api
API_PORT=3000

# WebSocket живой статистики опросов — порт сервиса ws
STATS_WS_PORT=3001

# Опционально: публичный URL Mini App (для production)
VITE_APP_URL=https://stachkagrosh.local/

# URL WebSocket сервера статистики для Mini App / плагина Figma (при сборке frontend).
# Локально без nginx: ws://localhost:3001
# Через nginx (Docker): wss://${DOMAIN}/ws или https://${DOMAIN} с путём /ws
# VITE_STATS_WS_URL=wss://your-domain.com/ws
# Опционально: явный API URL (без /api на конце)
# VITE_API_URL=https://your-domain.com

# PostgreSQL
POSTGRES_USER=stachka
POSTGRES_PASSWORD=stachka
POSTGRES_DB=stachka
DATABASE_URL=postgresql://stachka:stachka@localhost:5432/stachka

# Internal API → WS broadcast URL
WS_INTERNAL_URL=http://localhost:3001

# Tap game
TAP_GOAL=100

# Reaction race
REACTION_COUNTDOWN_SECONDS=3
REACTION_LEADERBOARD_DELAY_SECONDS=5
# Bingo: task id for "tap 10 times" (default: cmmgvekeb00036po386wfmw90)
# BINGO_TAP10_TASK_ID=cmmgvekeb00036po386wfmw90

# Bingo: task id for "vote in all polls" (default: cmmgveph300046po36vjutr1n)
# BINGO_POLLS_TASK_ID=cmmgveph300046po36vjutr1n

# Bingo: task id for "top 3 in reaction round" (default: cmmgveu7f00056po34mmt5zk6)
# BINGO_REACTION_TOP3_TASK_ID=cmmgveu7f00056po34mmt5zk6

# Bingo: task id for "complete 3 in a row" (default: cmmgvf8xv00086po3xga60bms)
# BINGO_LINE_TASK_ID=cmmgvf8xv00086po3xga60bms

# Bingo: task id for "press all haptic buttons" (default: cmmgveyhg00066po3yrtqv57l)
# BINGO_HAPTIC_TASK_ID=cmmgveyhg00066po3yrtqv57l

# Bingo: task id for "share to Stories" (default: cmmgve2my00006po33b1fewro)
# BINGO_SHARE_STORIES_TASK_ID=cmmgve2my00006po33b1fewro
# Bingo: task id for "share to chat" (default: cmmgveaow00016po3ft11qhmq)
# BINGO_SHARE_CHAT_TASK_ID=cmmgveaow00016po3ft11qhmq

# Telegram Stars support
TG_STARS_SUPPORT_AMOUNT=1
# Optional: verify Telegram webhook secret header
# TG_WEBHOOK_SECRET=your_secret_token
