# Admin (Telegram): comma-separated Telegram user IDs. Empty = allow all (dev).
# TG_ADMIN_USER_IDS=7409015534

# Display: token for /api/display/* (big screen без Telegram). Empty = allow (dev).
# DISPLAY_TOKEN=your_secret_token

# Telegram Bot API (для бота Mini App)
TG_BOT_API=your_bot_token

# VK Mini App (подпись launch params, опционально совпадение vk_app_id)
# VK_APP_ID=123456
# VK_APP_SECRET=your_app_secret
# VK_GROUP_TOKEN=community_messages_key
# VK_API_VERSION=5.131
# VK_ADMIN_USER_IDS=123,456
# Callback API сообщества:
# VK_CALLBACK_SECRET=...
# VK_CALLBACK_CONFIRMATION=строка_из_настроек_VK

# Dev: домен для HTTPS (ngrok, cloudflared). После смены — ./scripts/gen-ssl.sh
DOMAIN=localhost

API_PORT=3000
STATS_WS_PORT=3001

POSTGRES_USER=stachka
POSTGRES_PASSWORD=stachka
POSTGRES_DB=stachka
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Tap game (default 100)
TAP_GOAL=100

# Reaction race (defaults: 3, 5)
REACTION_COUNTDOWN_SECONDS=3
REACTION_LEADERBOARD_DELAY_SECONDS=5

# Bingo task IDs (опционально, есть defaults в коде)
# BINGO_POLLS_TASK_ID=...
# BINGO_TAP10_TASK_ID=...
# BINGO_REACTION_TOP3_TASK_ID=...
# BINGO_LINE_TASK_ID=...
# BINGO_HAPTIC_TASK_ID=...
# BINGO_SHARE_STORIES_TASK_ID=...
# BINGO_SHARE_CHAT_TASK_ID=...
# BINGO_QR_TASK_ID=...
