# Admin (Telegram): comma-separated Telegram user IDs. Empty = allow all (dev).
# TG_ADMIN_USER_IDS=7409015534

# Display: token for /api/display/* (big screen без Telegram). Empty = allow (dev).
# DISPLAY_TOKEN=your_secret_token

# Telegram Bot API (для бота Mini App)
TG_BOT_API=your_bot_token

# Webhook: POST https://<ваш-хост>/api/telegram/webhook — в BotFather задайте secret_token и укажите тот же секрет здесь (пусто = без проверки, только для dev)
# TG_WEBHOOK_SECRET=случайная_строка
# HTTPS URL мини-приложения для inline-кнопки «Открыть приложение» при /start
# TG_MINI_APP_PUBLIC_URL=https://open-conf-rnd.pro

# VK Mini App (подпись launch params, опционально совпадение vk_app_id)
# VK_APP_ID=123456
# VK_APP_SECRET=your_app_secret
# VK_GROUP_TOKEN=community_messages_key
# VK_API_VERSION=5.131
# VK_ADMIN_USER_IDS=123,456
# Callback API сообщества:
# VK_CALLBACK_SECRET=...
# VK_CALLBACK_CONFIRMATION=строка_из_настроек_VK

# Dev: домен для HTTPS (ngrok, cloudflared). После смены — ./scripts/gen-ssl.sh
DOMAIN=localhost

API_PORT=3000
STATS_WS_PORT=3001

POSTGRES_USER=stachka
POSTGRES_PASSWORD=stachka
POSTGRES_DB=stachka
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Tap game (default 100)
TAP_GOAL=100

# Reaction race (defaults: 3, 5)
REACTION_COUNTDOWN_SECONDS=3
REACTION_LEADERBOARD_DELAY_SECONDS=5

# Bingo task IDs (как в seed: npm run seed:bingo из папки api)
BINGO_POLLS_TASK_ID=stachka_bingo_polls
BINGO_TAP10_TASK_ID=stachka_bingo_tap10
BINGO_REACTION_TOP3_TASK_ID=stachka_bingo_reaction_top3
BINGO_LINE_TASK_ID=stachka_bingo_line
BINGO_HAPTIC_TASK_ID=stachka_bingo_haptic
BINGO_SHARE_STORIES_TASK_ID=stachka_bingo_share_stories
BINGO_SHARE_CHAT_TASK_ID=stachka_bingo_share_chat
BINGO_QR_TASK_ID=stachka_bingo_qr
BINGO_MERGE2048_TASK_ID=c3e7f1a4-8b2d-4c9e-a3f6-1d8e7b2c4a9f

# Порог плитки для зачёта бинго на /merge2048 (по умолчанию 512)
# MERGE2048_BINGO_MIN_TILE=512

# Ссылка в личку бота после скана QR «обратная связь» на слайде (код stachka-feedback-form-qr)
# FEEDBACK_FORM_URL=https://forms.yandex.ru/cloud/698dbe0f6d2d734220a9f7bc/?stachka_ul26=62

# Frontend (опционально): привязка аккаунтов на /register
# В vite dev без этой строки подставится test_stachka_grosh_bot; в prod-сборке — stachkagrosh_bot
# VITE_TG_BOT_USERNAME=stachkagrosh_bot
# VITE_VK_MINI_APP_URL=https://vk.com/app54525265
# JS API Карт (слайд маршрута в презентации): https://developer.tech.yandex.ru/services/
# VITE_YANDEX_MAPS_API_KEY=
