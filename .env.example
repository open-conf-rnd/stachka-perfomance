# Admin: comma-separated Telegram user IDs. Empty = allow all (dev).
# ADMIN_USER_IDS=7409015534

# Telegram Bot API (для бота Mini App)
TG_BOT_API=your_bot_token

# Dev: домен для HTTPS (ngrok, cloudflared). После смены — ./scripts/gen-ssl.sh
DOMAIN=localhost

# API и WebSocket порты
API_PORT=3000
STATS_WS_PORT=3001

# Production / сборка frontend
VITE_APP_URL=https://stachkagrosh.local/
# VITE_STATS_WS_URL=wss://your-domain.com/ws

# PostgreSQL (для dev: docker-compose и локальный api)
POSTGRES_USER=stachka
POSTGRES_PASSWORD=stachka
POSTGRES_DB=stachka
DATABASE_URL=postgresql://stachka:stachka@localhost:5432/stachka

# API → WS broadcast (в Docker dev задаётся compose)
WS_INTERNAL_URL=http://localhost:3001

# Tap game (default 100)
TAP_GOAL=100

# Reaction race (defaults: 3, 5)
REACTION_COUNTDOWN_SECONDS=3
REACTION_LEADERBOARD_DELAY_SECONDS=5

# Bingo task IDs (опционально, есть defaults в коде)
# BINGO_POLLS_TASK_ID=...
# BINGO_TAP10_TASK_ID=...
# BINGO_REACTION_TOP3_TASK_ID=...
# BINGO_LINE_TASK_ID=...
# BINGO_HAPTIC_TASK_ID=...
# BINGO_SHARE_STORIES_TASK_ID=...
# BINGO_SHARE_CHAT_TASK_ID=...
# BINGO_QR_TASK_ID=...
# BINGO_STARS_TASK_ID=...

# Telegram Stars
TG_STARS_SUPPORT_AMOUNT=1
# TG_WEBHOOK_SECRET=...
